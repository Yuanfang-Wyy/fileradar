{
  "name": "scout",
  "version": "0.1.0",
  "description": "Mac 桌面文件检索工具，功能对标 Windows Everything",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --config electron-builder.config.cjs",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test": "vitest",
    "rebuild:node": "pnpm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "chokidar": "^3.6.0",
    "electron-log": "^5.1.7",
    "electron-store": "^8.2.0",
    "node-global-key-listener": "^0.3.0",
    "pinyin-pro": "^3.28.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@tanstack/react-virtual": "^3.10.8",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "cmdk": "^1.0.0",
    "electron": "^28.3.3",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.4"
  }
}
